<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog</title>
    <link rel="stylesheet" href="css/estilo.css">
</head>
<body>

    <nav>
        <div class="nav-link"><a href="projects.html">Projetos</a></div>
        <div class="nav-link"><a href="/blog">Blog</a></div>
    </nav>

    <main>
        <section>
            <h2>Blog</h2>

            <a href="cadastrar_post.html" class="btn">Novo Post</a>

            <% if (listaPosts.length == 0) { %>
                <p>Nenhum post ainda.</p>
            <% } %>

            <% for (var i = 0; i < listaPosts.length; i++) { %>
                <div class="post-card">
                    <h3><%= listaPosts[i].titulo %></h3>
                    <p class="resumo"><%= listaPosts[i].resumo %></p>
                    <p class="conteudo"><%= listaPosts[i].conteudo %></p>
                </div>
            <% } %>
        </section>
    </main>

</body>
</html>
